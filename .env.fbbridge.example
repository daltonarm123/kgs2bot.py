# Core bridge destination
BRIDGE_HTTP_URL=https://kg2recon-production.up.railway.app/api/bridge/report
BRIDGE_HTTP_TOKEN=replace_with_bridge_token
BRIDGE_HTTP_SOURCE=facebook-messenger

# Facebook account
FB_MESSENGER_EMAIL=replace_with_fb_email
FB_MESSENGER_PASSWORD=replace_with_fb_password

# Watch targets
FB_MESSENGER_CHAT_NAMES=mom's knights in training,a team only
FB_MESSENGER_HEADLESS=false
FB_MESSENGER_POLL_SECONDS=15
FB_MESSENGER_LOOKBACK_MESSAGES=50

# Local persistence
FB_MESSENGER_PROFILE_DIR=.fb_messenger_profile
FB_MESSENGER_STATE_PATH=.fb_messenger_bridge_state.json

# One-time login bootstrap mode
FB_MESSENGER_LOGIN_ONLY=false
